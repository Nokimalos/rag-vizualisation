# Root env for the production compose (docker-compose.prod.yml).
# Copy to .env at the repo root:  cp .env.prod.example .env
#
# Your public domain (DNS A record must point to the server's IP).
# Caddy will auto-provision an HTTPS certificate for it.
DOMAIN=ragviz.example.com
#
# For quick HTTP-only testing without a domain, use instead:
# DOMAIN=:80
