# LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
VLLM_BASE_URL=
VLLM_MODEL=

# Embedding Providers
COHERE_API_KEY=

# Vector DB — ChromaDB is built-in and the default.
CHROMA_PERSIST_DIR=./data/chroma
# Optional backends: set a value to register them (then switch via the UI/API).
# QDRANT_URL=http://localhost:6333
# PGVECTOR_CONNECTION_STRING=postgresql://user:pass@localhost:5432/ragviz
# Embedding dimension for Qdrant/pgvector collections (OpenAI=1536, nomic-embed-text=768)
VECTOR_DIM=1536

# App
UPLOAD_DIR=./uploads
DATABASE_URL=./data/rag_viz.db
# Comma-separated list of allowed CORS origins (frontend URLs)
CORS_ORIGINS=http://localhost:5173
